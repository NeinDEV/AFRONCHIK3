-- ============================================================
-- Xodimlar davomati boti uchun ma'lumotlar bazasi sxemasi
-- PostgreSQL (Neon) uchun mo'ljallangan, idempotent (qayta ishga
-- tushirilsa xato bermaydi)
-- ============================================================

CREATE TABLE IF NOT EXISTS employees (
  id SERIAL PRIMARY KEY,
  telegram_id BIGINT UNIQUE NOT NULL,
  full_name VARCHAR(150) NOT NULL,
  position VARCHAR(100),
  is_active BOOLEAN NOT NULL DEFAULT TRUE,
  created_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE TABLE IF NOT EXISTS work_schedules (
  id SERIAL PRIMARY KEY,
  employee_id INT NOT NULL REFERENCES employees(id) ON DELETE CASCADE,
  shift_start TIME NOT NULL,
  shift_end TIME NOT NULL,
  crosses_midnight BOOLEAN NOT NULL DEFAULT FALSE,
  shift_order INT NOT NULL DEFAULT 1,
  is_active BOOLEAN NOT NULL DEFAULT TRUE,
  created_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE TABLE IF NOT EXISTS season_settings (
  id SERIAL PRIMARY KEY,
  season VARCHAR(10) NOT NULL CHECK (season IN ('summer', 'winter')),
  start_date DATE NOT NULL,
  end_date DATE NOT NULL,
  min_hours_per_day NUMERIC(4,2) NOT NULL,
  base_rate_per_hour NUMERIC(10,2) NOT NULL,
  overtime_rate_per_hour NUMERIC(10,2) NOT NULL,
  is_active BOOLEAN NOT NULL DEFAULT TRUE,
  created_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE TABLE IF NOT EXISTS attendance_records (
  id SERIAL PRIMARY KEY,
  employee_id INT NOT NULL REFERENCES employees(id) ON DELETE CASCADE,
  check_in_time TIMESTAMPTZ,
  check_out_time TIMESTAMPTZ,
  check_in_video_file_id TEXT,
  check_out_video_file_id TEXT,
  worked_hours NUMERIC(6,2),
  is_late BOOLEAN NOT NULL DEFAULT FALSE,
  late_minutes INT NOT NULL DEFAULT 0,
  status VARCHAR(20) NOT NULL DEFAULT 'open',
  created_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE TABLE IF NOT EXISTS penalty_rules (
  id SERIAL PRIMARY KEY,
  grace_minutes INT NOT NULL DEFAULT 30,
  penalty_amount NUMERIC(10,2) NOT NULL DEFAULT 30000,
  updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE TABLE IF NOT EXISTS penalties (
  id SERIAL PRIMARY KEY,
  employee_id INT NOT NULL REFERENCES employees(id) ON DELETE CASCADE,
  attendance_id INT REFERENCES attendance_records(id) ON DELETE SET NULL,
  amount NUMERIC(10,2) NOT NULL,
  reason VARCHAR(255),
  is_cancelled BOOLEAN NOT NULL DEFAULT FALSE,
  adjusted_by_admin_id BIGINT,
  created_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE TABLE IF NOT EXISTS settings_history (
  id SERIAL PRIMARY KEY,
  changed_by BIGINT NOT NULL,
  change_type VARCHAR(50) NOT NULL,
  old_value JSONB,
  new_value JSONB,
  changed_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE TABLE IF NOT EXISTS monthly_reports (
  id SERIAL PRIMARY KEY,
  employee_id INT NOT NULL REFERENCES employees(id) ON DELETE CASCADE,
  month DATE NOT NULL,
  total_hours NUMERIC(8,2) NOT NULL DEFAULT 0,
  total_salary NUMERIC(12,2) NOT NULL DEFAULT 0,
  total_penalties NUMERIC(10,2) NOT NULL DEFAULT 0,
  final_amount NUMERIC(12,2) NOT NULL DEFAULT 0,
  generated_at TIMESTAMPTZ NOT NULL DEFAULT now(),
  UNIQUE(employee_id, month)
);

-- Botga /start bosgan, lekin hali xodim sifatida ro'yxatga olinmagan
-- foydalanuvchilarning ID sini vaqtincha eslab qolish uchun (Adminga
-- ID ni ko'chirib berish osonroq bo'lishi uchun ishlatilmaydi, shunchaki log)
CREATE TABLE IF NOT EXISTS pending_users (
  telegram_id BIGINT PRIMARY KEY,
  username VARCHAR(100),
  first_seen TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_attendance_employee_time
  ON attendance_records(employee_id, check_in_time);

CREATE INDEX IF NOT EXISTS idx_attendance_status
  ON attendance_records(employee_id, status);

CREATE INDEX IF NOT EXISTS idx_penalties_employee
  ON penalties(employee_id);

CREATE INDEX IF NOT EXISTS idx_employees_telegram_id
  ON employees(telegram_id);

CREATE INDEX IF NOT EXISTS idx_schedules_employee
  ON work_schedules(employee_id);

-- Dastlabki (default) jarima qoidasi, agar hali kiritilmagan bo'lsa
INSERT INTO penalty_rules (grace_minutes, penalty_amount)
SELECT 30, 30000
WHERE NOT EXISTS (SELECT 1 FROM penalty_rules);
